# Normalize line endings so large game files don't thrash on Windows
# (core.autocrlf + mixed LF/CRLF makes diffs look like full-file rewrites)
* text=auto eol=lf

*.html text eol=lf
*.js   text eol=lf
*.css  text eol=lf
*.md   text eol=lf
*.svg  text eol=lf

*.jpg  binary
*.jpeg binary
*.png  binary
*.gif  binary
*.webp binary
*.ico  binary
